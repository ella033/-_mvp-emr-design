{
  "name": "nextgen-emr",
  "version": "0.1.0",
  "private": true,
  "author": "UBcare",
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "node scripts/compile-print-styles.js",
    "build": "next build",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "check-types": "tsc --noEmit --pretty",
    "clean": "rimraf .next out coverage",
    "commit": "cz",
    "dev": "pnpm run dev:next",
    "dev:next": "next dev -p 8080 --turbopack",
    "dev:8081": "next dev -p 8081 --turbopack",
    "generate:api": "node scripts/generate-api-types.js",
    "generate:api:check": "node scripts/generate-api-types.js --check",
    "generate:e2e-manifest": "node scripts/generate-scenario-manifest.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "start": "next start",
    "test": "vitest run",
    "test:coverage": "pnpm run test:coverage:ui-contract",
    "test:coverage:strict": "pnpm run test:coverage:ui-contract:gate",
    "test:coverage:ui-contract": "vitest run --coverage",
    "test:coverage:ui-contract:gate": "VITEST_COVERAGE_PROFILE=ui-contract-gate vitest run --coverage",
    "graph:testid": "tsx scripts/insert-testids.ts",
    "graph:testid:dry": "tsx scripts/insert-testids.ts --dry-run",
    "graph:extract": "tsx scripts/extract-graph.ts",
    "graph:tc": "tsx scripts/generate-tc.ts",
    "graph:pipeline": "tsx scripts/extract-graph.ts && tsx scripts/generate-tc.ts"
  },
